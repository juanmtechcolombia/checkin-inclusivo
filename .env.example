# ===== App de Check-in Inclusivo =====

# Database
DATABASE_URL="postgresql://checkin:checkin_pass@localhost:5432/checkin_inclusivo?schema=public"

# JWT
JWT_SECRET="dev-secret-change-in-production-min-32-chars!!"
JWT_EXPIRATION="24h"

# OTP
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6

# QR
QR_EXPIRY_MINUTES=10
QR_SECRET="dev-qr-secret-change-in-production"

# Server
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# Encryption key for sensitive data vault (32 bytes hex)
VAULT_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Node environment
NODE_ENV=development
